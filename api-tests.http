@baseUrl = http://localhost:8080
@adminToken = replace-with-admin-jwt
@dispatcherToken = replace-with-dispatcher-jwt
@customerToken = replace-with-customer-jwt
@courierToken = replace-with-courier-jwt

### Health check
GET {{baseUrl}}/actuator/health

### OpenAPI document
GET {{baseUrl}}/v3/api-docs

### Register customer
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "customer@example.com",
  "password": "StrongPass123"
}

### Create dispatcher user
POST {{baseUrl}}/api/v1/auth/users
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "email": "dispatcher@example.com",
  "password": "StrongPass123",
  "role": "DISPATCHER"
}

### Login
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "customer@example.com",
  "password": "StrongPass123"
}

### Create delivery order
POST {{baseUrl}}/api/v1/orders
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "pickupAddress": "Istiklal Cd. No:1, Beyoglu",
  "pickupLatitude": 41.036900,
  "pickupLongitude": 28.985000,
  "dropoffAddress": "Bagdat Cd. No:10, Kadikoy",
  "dropoffLatitude": 40.970000,
  "dropoffLongitude": 29.057000
}

### List customer delivery orders
GET {{baseUrl}}/api/v1/orders
Authorization: Bearer {{customerToken}}

### Get customer delivery order
GET {{baseUrl}}/api/v1/orders/1
Authorization: Bearer {{customerToken}}

### Get customer delivery order timeline
GET {{baseUrl}}/api/v1/orders/1/timeline
Authorization: Bearer {{customerToken}}

### Cancel customer delivery order
DELETE {{baseUrl}}/api/v1/orders/1
Authorization: Bearer {{customerToken}}

### Update courier availability
PATCH {{baseUrl}}/api/v1/couriers/me/availability
Authorization: Bearer {{courierToken}}
Content-Type: application/json

{
  "status": "AVAILABLE"
}

### Auto-assign nearest eligible courier
POST {{baseUrl}}/api/v1/dispatch/orders/1/auto-assign
Authorization: Bearer {{dispatcherToken}}

### List operational orders
GET {{baseUrl}}/api/v1/dispatch/orders
Authorization: Bearer {{dispatcherToken}}

### Manually assign a courier
POST {{baseUrl}}/api/v1/dispatch/orders/1/assign
Authorization: Bearer {{dispatcherToken}}
Content-Type: application/json

{
  "courierId": 1
}

### Update courier location
PATCH {{baseUrl}}/api/v1/couriers/me/location
Authorization: Bearer {{courierToken}}
Content-Type: application/json

{
  "latitude": 41.008200,
  "longitude": 28.978400
}

### Mark assigned courier order as picked up
POST {{baseUrl}}/api/v1/couriers/me/orders/1/pickup
Authorization: Bearer {{courierToken}}

### Mark picked-up courier order as delivered
POST {{baseUrl}}/api/v1/couriers/me/orders/1/deliver
Authorization: Bearer {{courierToken}}
